{
  "compileOnSave": true,
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2024",
    "noImplicitAny": true,
    "strictNullChecks": false,
    "sourceMap": true,
    "outDir": "dist",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "resolveJsonModule": true,
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": true,
    "types": ["node"],
    "lib": ["dom", "es2024"]
  },
  "include": ["api/**/*"],
  "exclude": ["node_modules", "dist"]
}
